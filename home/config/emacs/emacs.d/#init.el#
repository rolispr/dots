    "Collapse region, and send to love2d REPL."
    (interactive)
    (remove-newlines-in-region)
    (lisp-eval-defun))
  :bind ((:map fennel-mode-map
	       ("C-c C-e" . love2d-collapse-and-eval-defun)
	       ("C-c C-r" . remove-newlines-in-region))))

