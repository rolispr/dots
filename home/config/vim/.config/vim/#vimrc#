# Experiments {{{

def SwitchToBuffer()
    var buffers = []
    for i in range(1, bufnr('$') + 1)
        var bufname = bufname(i)
        if bufname !=# ""
            buffers->add(i .. ': ' .. bufname)
        endif
    endfor

    var choice = inputlist(['Select a buffer:'] + buffers)
    if choice > 0 && choice <= len(buffers)
        var selected_bufnr = split(buffers[choice - 1], ':')[0]
        execute 'buffer' selected_bufnr
    endif
enddef

