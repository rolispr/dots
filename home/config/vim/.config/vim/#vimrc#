# A configuration for vim9+
## 
# Programmers shape ideas into text.
# 
# That text gets turned into numbers and those numbers bump into other numbers and make things happen.
# As programmers, we use text editors to get our ideas out of our heads and create the chunks of text we call "programs".
# - Steve Losh from Learn vimscript the hard way
## 
# Common options {{{
## General options {{{
syntax enable
autocmd ColorScheme * highlight VertSplit cterm=NONE ctermfg=Green ctermbg=NONE
colorscheme zaibatsu
filetype plugin indent on
set autochdir
set autoread
set backspace=indent,eol,start
set cdhome
set cursorline cursorlineopt=number,line
set expandtab
set fillchars+=foldopen:▾,foldsep:│,foldclose:▸
set fillchars+=vert:│
set foldcolumn=6
set foldmethod=marker
set hidden
set history=10000
set incsearch hlsearch
set laststatus=2
set nobackup
set nocompatible
set noswapfile
set number relativenumber
set tabstop=4 softtabstop=4 shiftwidth=4
set termguicolors
set wildcharm=<tab>
set wildmenu wildoptions=pum
#set ttimeoutlen=0
#set matchtime=10
#set shell=bash
## }}}
## Status line {{{

set statusline=\ %<\ %t\ %m\ %r%{getcwd()}\ %h%=%y
set statusline+=\ %{&fileencoding}\ %{&fileformat}
set statusline+=\ l/c:[%4l:%-4c]\ eof:\ %-4L
set statusline+=\ U+%-4B\ 
## }}}
## Globals {{{
