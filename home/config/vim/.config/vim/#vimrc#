def CaptureAndSendToTerminal()
    var start_pos = getpos("'<")
    var end_pos = getpos("'>")

    var start_line = start_pos[1]
    var end_line = end_pos[1]

    var lines = getline(start_line, end_line)
    var command = join(lines, "\n")
    var term_bufnr = 0
    for buf in range(1, bufnr('$') + 1)
        if getbufvar(buf, '&buftype') ==# 'terminal' && getbufvar(buf, '&term_name') ==# 'myterminal'
            term_bufnr = buf
            break
        endif
    endfor

    if !exists("t:term_bufnr")
        new
        setlocal nobuflisted
        call term_start(&shell, {'term_name': 'myterminal'})
        term_bufnr = bufnr('%')
    endif

    exec 'buffer' term_bufnr
    call feedkeys("i" .. command .. "\<CR>\<Esc>")
enddef

